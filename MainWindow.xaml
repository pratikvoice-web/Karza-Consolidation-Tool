<Window x:Class="KarzaConsolidator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Karza Deep Consolidation Engine v2026.06" Height="680" Width="850" Background="#F1F5F9" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F172A" CornerRadius="6" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="KARZA DEEP CONSOLIDATION ENGINE v2026.06" Foreground="#38BDF8" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="Enterprise Data Aggregation, Subledger Matrixing &amp; Revenue Reconciliation Engine" Foreground="#94A3B8" FontSize="12" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Source Directory Path (Raw Karza State Reports)" FontSize="12" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSourcePath" Grid.Column="0" Padding="10,8" VerticalContentAlignment="Center" Background="White" BorderBrush="#CBD5E1" FontSize="12"/>
                <Button x:Name="BtnBrowseSource" Grid.Column="1" Content="Browse Folder" Padding="15,0" Margin="10,0,0,0" Click="BtnBrowseSource_Click" Background="#E2E8F0" BorderBrush="#CBD5E1" FontWeight="SemiBold"/>
            </Grid>

            <TextBlock Text="Destination Output Directory Path (Consolidated Ledger Export Destination)" FontSize="12" FontWeight="Bold" Foreground="#334155" Margin="0,0,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtDestPath" Grid.Column="0" Padding="10,8" VerticalContentAlignment="Center" Background="White" BorderBrush="#CBD5E1" FontSize="12"/>
                <Button x:Name="BtnBrowseDest" Grid.Column="1" Content="Browse Folder" Padding="15,0" Margin="10,0,0,0" Click="BtnBrowseDest_Click" Background="#E2E8F0" BorderBrush="#CBD5E1" FontWeight="SemiBold"/>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,5,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="LblExtractStatus" Text="Extraction Matrix Layer: Execution Idle" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                <ProgressBar x:Name="ProgressExtract" Height="12" Minimum="0" Maximum="100" Margin="0,0,0,12" Foreground="#0EA5E9" Background="#E2E8F0" BorderThickness="0"/>
                
                <TextBlock x:Name="LblCompileStatus" Text="Analytical Ledger Compilation: Execution Idle" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                <ProgressBar x:Name="ProgressCompile" Height="12" Minimum="0" Maximum="100" Foreground="#D946EF" Background="#E2E8F0" BorderThickness="0"/>
            </StackPanel>
            <Button x:Name="BtnRun" Grid.Column="1" Content="Execute Engine" Padding="35,0" Margin="25,0,0,0" FontSize="14" FontWeight="Bold" Foreground="White" Background="#0EA5E9" BorderThickness="0" Click="BtnRun_Click"/>
        </Grid>

        <GroupBox Grid.Row="3" Header="Live Process Pipeline Audit Log" FontSize="11" FontWeight="Bold" Foreground="#475569" Margin="0,0,0,15">
            <TextBox x:Name="TxtLog" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#0F172A" Foreground="#E2E8F0" FontFamily="Consolas" FontSize="12" Padding="12" Margin="0,5,0,0" BorderThickness="0"/>
        </GroupBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
            <Button x:Name="BtnOpenFolder" Content="Open Export Destination Location" Padding="15,10" Visibility="Collapsed" Click="BtnOpenFolder_Click" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
